{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "card.schema.json",
  "title": "Codex Card",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "subtitle",
    "era",
    "region",
    "date",
    "rarity",
    "summary",
    "importance",
    "facts",
    "tags",
    "stats",
    "image"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z0-9_]+$"
    },
    "type": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "original": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "era": {
      "type": "string"
    },
    "region": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "rarity": {
      "enum": [
        "RARE",
        "EPIC",
        "LEGENDARY",
        "MYTHIC"
      ]
    },
    "difficulty": {
      "type": "number",
      "minimum": 1,
      "maximum": 10
    },
    "summary": {
      "type": "string",
      "minLength": 20
    },
    "importance": {
      "type": "string",
      "minLength": 20
    },
    "facts": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "stats": {
      "type": "object",
      "required": [
        "influence",
        "complexity",
        "legacy",
        "military",
        "culture",
        "politics",
        "religion",
        "economy",
        "connections"
      ]
    },
    "image": {
      "type": "object",
      "required": [
        "file",
        "caption",
        "credit",
        "license"
      ]
    }
  },
  "additionalProperties": true
}
