{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Learning Mission",
  "type": "object",
  "required": [
    "missionId",
    "duration",
    "objectives",
    "story",
    "chronology",
    "concepts",
    "causeEffect",
    "theory",
    "activity"
  ],
  "properties": {
    "missionId": {
      "type": "string"
    },
    "duration": {
      "type": "integer",
      "minimum": 3
    },
    "objectives": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "story": {
      "type": "array",
      "minItems": 2
    },
    "chronology": {
      "type": "array",
      "minItems": 3
    },
    "concepts": {
      "type": "array",
      "minItems": 3
    },
    "causeEffect": {
      "type": "object"
    },
    "activity": {
      "type": "object"
    },
    "theory": {
      "type": "object",
      "required": [
        "title",
        "readingMinutes",
        "lead",
        "paragraphs",
        "sources",
        "historicityNotes"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 5
        },
        "readingMinutes": {
          "type": "integer",
          "minimum": 3
        },
        "lead": {
          "type": "string",
          "minLength": 30
        },
        "paragraphs": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string",
            "minLength": 120
          }
        },
        "sources": {
          "type": "array",
          "minItems": 1
        },
        "historicityNotes": {
          "type": "array",
          "minItems": 2
        }
      }
    }
  }
}
